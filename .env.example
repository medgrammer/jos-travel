NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxx

# Server-only. Keep this secret outside the browser.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxx

# First admin bootstrap. After this email signs in, the server promotes its profile to role = admin.
JOS_TRAVEL_ADMIN_EMAILS=admin@jostravel.com

# OpenAI conversation.
OPENAI_API_KEY=sk-proj_xxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-5.4-mini
OPENAI_FALLBACK_MODEL=gpt-5.4-mini

# Public production URL used for payment return pages.
NEXT_PUBLIC_SITE_URL=https://jostravel.site

# PawaPay server-only payment configuration.
PAWAPAY_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxx
PAWAPAY_API_BASE_URL=https://api.pawapay.io
PAWAPAY_COUNTRY=CMR
PAWAPAY_CURRENCY=XAF

# Billing configuration.
CLOUD_SUBSCRIPTION_MONTHLY_USD=40
CLOUD_SUBSCRIPTION_ANNUAL_USD=400

# Optional fixed fallback rate. If omitted, the server tries live USD -> XAF conversion at payment time.
USD_TO_XAF_RATE=
